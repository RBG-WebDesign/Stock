{
  "pipeline": {
    "universe_limit": 250,
    "model": "google/gemini-3-flash-preview",
    "prompt_mode": "master_analyst",
    "save_prompts": false,
    "news_summary_max_chars": 500,
    "max_recent_articles": 10
  },
  "market_cap": {
    "min_m": 50,
    "max_m": 5000
  },
  "fundamental_filters": {
    "min_eps_growth": 5.0,
    "min_rev_growth": 5.0,
    "max_rev_growth": null,
    "min_prev_eps": null,
    "max_prev_eps": null,
    "min_latest_eps": null,
    "require_acceleration": false
  },
  "technical_filters": [
    "price > sma_50",
    "price > sma_100",
    "price > sma_200",
    "sma_50 > sma_100",
    "sma_100 > sma_200",
    "price >= 1.20 * low_52w",
    "price >= 0.80 * high_52w"
  ]
}
