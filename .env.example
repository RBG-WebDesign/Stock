# =============================================================================
# Techno-Quantamental Analyzer Environment Configuration
# =============================================================================

# Financial Modeling Prep (FMP) API Key
# Primary source for all fundamental metrics and price data.
FMP_API_KEY=your_fmp_api_key_here

# FMP Subscription Plan (starter, premium)
# Set to 'premium' if you have access to Bulk API endpoints.
FMP_PLAN=starter

# OpenRouter API Key
# Used for synchronous prompt testing and model experimentation.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Native Provider Keys
# Required for native Batch API calls (OpenAI/Anthropic) to leverage 50% discounts.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Pipeline Settings
# The default model identifier to be used by the orchestrator.
DEFAULT_MODEL=anthropic/claude-3.5-sonnet